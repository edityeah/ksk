PORT=8787
JWT_SECRET=ksk-dev-secret-change-me
DATABASE_URL="file:./data/ksk.db"
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
RATE_LIMIT_PER_HOUR=50
ALLOWED_ORIGIN=http://localhost:5173

# Anam AI — real-time avatar (Career Counsellor, Mock Interviewer, Learning Assistant)
# Leave blank to use Anam's stock avatars (Mia + Lauren).
ANAM_API_KEY=
ANAM_AVATAR_ID=
ANAM_VOICE_ID=

# Zep Cloud — per-user conversation memory (long-term recall across avatar sessions)
ZEP_API_KEY=

# Cartesia — high-quality TTS with native Indian-language voices (Hindi, Tamil,
# Telugu, Bengali, Marathi, Punjabi, Kannada, Malayalam, Gujarati, Odia,
# Indian-English). Used for voice-mode calls (bypasses Anam, saves minutes).
# To use Cartesia voice INSIDE the avatar (video mode), upload the voice to
# lab.anam.ai → Voices → New (import from Cartesia) and set the resulting
# Anam voice id as ANAM_VOICE_ID above.
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-2

# OpenAI Realtime — drives hands-free voice calls via WebRTC. The server uses
# your real OPENAI_API_KEY to mint a short-lived ephemeral key that the browser
# uses to open a direct peer connection to OpenAI (server-side VAD, native
# barge-in, ~500ms perceived latency).
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# Voices: alloy · ash · ballad · coral · sage · shimmer · verse
OPENAI_REALTIME_VOICE=verse
