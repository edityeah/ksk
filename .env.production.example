# Copy to .env.production (which is gitignored) and fill in.
# Used by docker-compose.tunnel.yml only — dev stack uses server/.env.

# ── Database ───────────────────────────────────────────────────────────
# Strong random; never committed. Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=

# ── API ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=
ALLOWED_ORIGIN=https://ksk.adityeah.ai

# ── OpenAI (required) ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=verse
RATE_LIMIT_PER_HOUR=50

# ── Anam avatar (optional — copy from current Render env) ──────────────
ANAM_API_KEY=
ANAM_AVATAR_ID=
ANAM_VOICE_ID=

# ── Zep Cloud memory (optional) ────────────────────────────────────────
ZEP_API_KEY=

# ── Cartesia TTS (optional) ────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
CARTESIA_MODEL_ID=sonic-2
