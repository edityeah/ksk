# Keep build context small + fast. Everything in here is either
# regenerated inside the build or doesn't belong in the image.

# Source control + IDE
.git
.gitignore
.github
.vscode
.idea
.DS_Store

# Dev runtime artefacts (regenerated by `npm install` in the builder)
**/node_modules
**/.next
**/.turbo
**/.cache

# Build outputs — rebuilt inside the builder stage
web/dist
server/dist

# Local-only data — DB dumps, cloudflared creds, etc.
.local-data
*.sql
*.dump
cloudflared/credentials

# Environment files — should never be baked into an image.
# The compose stack passes env vars via env_file at runtime instead.
.env
.env.*
!.env.example

# Logs
*.log

# Markdown docs (not needed at runtime)
*.md
docs
