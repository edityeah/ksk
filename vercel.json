{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "installCommand": "npm install && cd web && npm install && cd ../server && npm install",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
